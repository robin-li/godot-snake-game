; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   property=value ; assign values to properties

config_version=5

[application]

config/name="Snake Game"
config/version="1.0.0"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.1", "4.2", "4.3")

[debug]

GDScript/warnings/unused_variable=1
GDScript/warnings/unused_parameter=1

[physics]

common/physics_ticks_per_second=10
